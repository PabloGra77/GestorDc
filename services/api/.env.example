# ─────────────────────────────────────────────────────────────────────────────
# GestorDoc CO — Variables de entorno: Backend API
# Copiar a .env y completar TODOS los valores antes de levantar el servicio.
# NUNCA commitear el .env real — este archivo .env.example sí va a Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Aplicación ────────────────────────────────────────────────────────────────
APP_NAME=gestordoc-api
# local | test | production
APP_ENV=production
APP_PORT=3001

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_HOST=gestordoc-postgres
DB_PORT=5432
DB_NAME=gestordoc
DB_USER=gestordoc_app
DB_PASSWORD=CAMBIAR_ESTA_CLAVE_SEGURA

# NUNCA usar true en test ni producción — el esquema lo controlan las migraciones
# En desarrollo local se puede habilitar temporalmente durante prototipado
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_ACCESS_SECRET=CAMBIAR_POR_CADENA_ALEATORIA_MINIMO_64_CHARS
JWT_REFRESH_SECRET=CAMBIAR_POR_CADENA_ALEATORIA_DIFERENTE_64_CHARS

# ── SMTP ──────────────────────────────────────────────────────────────────────
# Para Gmail usar App Passwords (no la contraseña principal de la cuenta)
SMTP_HOST=smtp.dominio.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notificaciones@dominio.com
SMTP_PASS=APP_PASSWORD_AQUI
SMTP_FROM="Gestor Documental <notificaciones@dominio.com>"

# ── URLs ──────────────────────────────────────────────────────────────────────
WEB_BASE_URL=https://tu-dominio.com

# ── Seguridad ─────────────────────────────────────────────────────────────────
PASSWORD_RESET_TTL_MINUTES=30
# Contraseña temporal generada al crear usuarios — cambiar en cada ambiente
DEFAULT_USER_PASSWORD=CAMBIAR_ESTA_CLAVE_TEMPORAL