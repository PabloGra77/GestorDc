APP_NAME=gestordoc-api
APP_ENV=production
APP_PORT=3001

DB_HOST=postgres
DB_PORT=5432
DB_NAME=gestordoc
DB_USER=gestordoc_app
DB_PASSWORD=CAMBIAR_ESTA_CLAVE
# NUNCA usar true en produccion — genera migraciones automáticas destructivas
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Secreto JWT — minimo 32 caracteres aleatorios. Generar con: openssl rand -hex 32
JWT_ACCESS_SECRET=CAMBIAR_POR_CLAVE_ALEATORIA_DE_64_CHARS

SMTP_HOST=smtp.dominio.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=correo@dominio.com
SMTP_PASS=app_password_o_clave_smtp
SMTP_FROM="Gestor Documental <correo@dominio.com>"
WEB_BASE_URL=https://tu-dominio.com
PASSWORD_RESET_TTL_MINUTES=30
DEFAULT_USER_PASSWORD=CAMBIAR_ESTA_CLAVE_TEMPORAL