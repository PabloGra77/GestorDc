# ─────────────────────────────────────────────────────────────────────────────
# GestorDoc CO — Variables de entorno: Frontend Web (Vite)
# Copiar a .env y completar antes de levantar el servidor.
# NUNCA commitear el .env real — este .env.example sí va a Git.
# Las variables Vite DEBEN comenzar con VITE_ para quedar expuestas al bundle.
# ─────────────────────────────────────────────────────────────────────────────

# URL base de la API — sin barra final
# Desarrollo local:
VITE_API_BASE_URL=http://localhost:3001/api
# Producción:
# VITE_API_BASE_URL=https://tu-dominio.com/api
